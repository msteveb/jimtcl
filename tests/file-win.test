source [file dirname [info script]]/testing.tcl

# These tests were auto-generated by Tcl 9.1a2
# using tcltest and "testsetplatform windows"
# to test file split, file dirname, file tail and file join

if {$tcl_platform(platform) ne "windows"} {
  needs cmd testsetplatform
  testsetplatform windows
}

proc test-path {path} {
  list [file split $path] [file dirname $path] [file tail $path]
}

proc test-join {args} {
  file join {*}$args
}

